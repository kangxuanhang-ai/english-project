# =============================================================================
# English 平台后端环境变量示例
# 复制为 server/.env 后填写真实值（勿提交 .env 到 Git）
# 主 API (3000) 与 AI 服务 (3001) 共用此文件
# =============================================================================

# 数据库连接字符串（主 API）
DATABASE_URL=postgresql://postgres:password@localhost:5432/english

# JWT 秘钥（生产环境请用足够长的随机字符串）
SECRET_KEY=change-me-in-production-use-openssl-rand

# MinIO（头像 / 课程封面）
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_BUCKET=avatar
# Docker 部署时：MINIO_ENDPOINT=minio，浏览器访问填公网反代基址
# MINIO_PUBLIC_BASE=http://101.37.235.230/minio

# DeepSeek（AI 聊天；主 API 知识库 embedding 也会读取 DEEPSEEK_API_KEY）
DEEPSEEK_API_KEY=
DEEPSEEK_API_MODEL=deepseek-chat
DEEPSEEK_REASONER_API_MODEL=deepseek-reasoner
DEEPSEEK_EMBEDDING_MODEL=deepseek-embed

# LangGraph 聊天历史库（可与 english 同实例不同库名）
AI_DATABASE_URL=postgresql://postgres:password@localhost:5432/langchain

# Bocha 联网搜索
BOCHA_SEARCH_URL=https://api.bochaai.com/v1/web-search
BOCHA_API_KEY=

# 支付宝沙箱（私钥/公钥填开放平台的一行 base64，不要换行）
ALIPAY_APP_ID=
ALIPAY_GATEWAY=https://openapi-sandbox.dl.alipaydev.com/gateway.do
ALIPAY_PUBLIC_KEY=
ALIPAY_PRIVATE_KEY=
# notify 基址：勿带 /api/v1/pay/notify（代码会自动拼接）
# 本地答辩 FRP 示例：http://你的公网IP:18080
ALIPAY_NOTIFY_URL=http://your-public-ip:18080
ALIPAY_RETURN_URL=http://localhost:8080/courses/index

# CORS（JSON 数组；本地 Vite 代理下 admin 可不跨域，生产或直连 API 时需配置）
# 8080=C 端  8081=B 端 admin
CORS_ORIGINS=["http://localhost:8080","http://localhost:8081"]

# 邮件 SMTP（单词记忆报告 digest；注册不使用验证码）
EMAIL_HOST=smtp.example.com
EMAIL_PORT=465
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=noreply@example.com
EMAIL_USE_SSL=true

# --- 知识库（有默认值，可不填）---
EMBEDDING_MODE=local
EMBEDDING_API_BASE=https://api.deepseek.com/v1
LOCAL_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DIMENSIONS=512
# 国内部署拉 HuggingFace 模型时使用（Docker compose 也会默认注入）
HF_ENDPOINT=https://hf-mirror.com
KNOWLEDGE_MAX_FILE_SIZE=20971520
KNOWLEDGE_CHUNK_SIZE=500
KNOWLEDGE_CHUNK_OVERLAP=50
KNOWLEDGE_MIN_SCORE=0.5

# --- 可选（当前未实现 / 多 worker 时用）---
# CLICKHOUSE_URL=
# CLICKHOUSE_USERNAME=
# CLICKHOUSE_PASSWORD=
# CLICKHOUSE_DATABASE=
# REDIS_URL=redis://localhost:6379/0
# RATE_LIMIT_STORAGE_URI=memory://
# ECDICT_CSV_PATH=/path/to/ecdict.csv

# LangSmith（可选；仅当 LANGCHAIN_API_KEY 非空时 AI 服务自动启用 tracing 与 Hub prompt 拉取）
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=english-chat
LANGCHAIN_EVAL_PROJECT=english-agent-eval
# Hub prompt 标识符：english-chat-{role}（见 scripts/push_prompts_to_hub.py）
# Agent 评测（Phase 3）：scripts/create_agent_eval_dataset.py + scripts/run_agent_eval.py
# AGENT_EVAL_USER_ID 建议设为数据库中真实用户 UUID（progress/推荐/购课用例需要）
AGENT_EVAL_USER_ID=eval-user

# English MCP Server（Claude Code CLI stdio；见 docs/superpowers/specs/2026-06-29-english-mcp-vocabulary-design.md）
ENGLISH_MCP_API_KEY=my-english-mcp
ENGLISH_MCP_USER_ID=8TkbEWt3cn5nM39Y8b6y
ENGLISH_MCP_DEMO_USER_ID=8TkbEWt3cn5nM39Y8b6y
MCP_DB_POOL_SIZE=5
MCP_DB_MAX_OVERFLOW=10
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=3002
