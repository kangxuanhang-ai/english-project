# =============================================================================
# 生产环境变量模板 — 复制为 deploy/.env（勿提交 Git）
# GitHub Actions 使用 Secrets.SERVER_ENV 写入 ECS 上的 /opt/english-project/.env
# =============================================================================

# --- Compose 基础设施（与 server/.env 同文件）---
POSTGRES_PASSWORD=change-me-strong-password
IMAGE_TAG=latest
GHCR_OWNER=kangxuanhang-ai

# --- 数据库（Docker 内网主机名 postgres）---
DATABASE_URL=postgresql://postgres:change-me-strong-password@postgres:5432/english
AI_DATABASE_URL=postgresql://postgres:change-me-strong-password@postgres:5432/langchain

SECRET_KEY=change-me-use-openssl-rand-hex-32

# MinIO：容器内连接 minio；浏览器通过 Nginx /minio/ 访问
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change-me-minio-secret
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_BUCKET=avatar
MINIO_PUBLIC_BASE=http://101.37.235.230/minio

DEEPSEEK_API_KEY=
DEEPSEEK_API_MODEL=deepseek-chat
DEEPSEEK_REASONER_API_MODEL=deepseek-reasoner
DEEPSEEK_EMBEDDING_MODEL=deepseek-embed

BOCHA_SEARCH_URL=https://api.bochaai.com/v1/web-search
# 联网搜索必填（博查 AI 开放平台申请）；留空则天气/新闻类问题无法联网
BOCHA_API_KEY=

# 支付宝沙箱
ALIPAY_APP_ID=
ALIPAY_GATEWAY=https://openapi-sandbox.dl.alipaydev.com/gateway.do
ALIPAY_PUBLIC_KEY=
ALIPAY_PRIVATE_KEY=
ALIPAY_NOTIFY_URL=http://101.37.235.230
ALIPAY_RETURN_URL=http://101.37.235.230/courses/index

CORS_ORIGINS=["http://101.37.235.230"]

EMAIL_HOST=smtp.qq.com
EMAIL_PORT=465
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=
EMAIL_USE_SSL=true

# 4GB ECS 若 AI 容器 OOM，可改为 api 走 DeepSeek embedding
EMBEDDING_MODE=local
EMBEDDING_API_BASE=https://api.deepseek.com/v1
LOCAL_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DIMENSIONS=512
# 国内 ECS 拉 HuggingFace 模型需镜像（compose 也会默认注入）
HF_ENDPOINT=https://hf-mirror.com

KNOWLEDGE_MAX_FILE_SIZE=20971520
KNOWLEDGE_CHUNK_SIZE=500
KNOWLEDGE_CHUNK_OVERLAP=50
KNOWLEDGE_MIN_SCORE=0.5

# English MCP HTTP（Claude Code 接入）
MCP_DB_POOL_SIZE=5
MCP_DB_MAX_OVERFLOW=10
MCP_HTTP_HOST=0.0.0.0
MCP_HTTP_PORT=3002
MCP_PUBLIC_URL=http://101.37.235.230/mcp
MCP_GRAMMAR_REQUIRE_KEY=false
